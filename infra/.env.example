# LangFlow Environment Configuration
# Architecture Decision Record: LANGFLOW_APL_INTEGRATION_PLAN.md
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#   nano .env
#
# Generate secure passwords:
#   openssl rand -base64 32

# ============================================================================
# PostgreSQL Configuration
# ============================================================================

POSTGRES_USER=langflow

# PostgreSQL password (REQUIRED - must be set)
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Database name (default: langflow)
# POSTGRES_DB=langflow

# ============================================================================
# LangFlow Configuration
# ============================================================================

# Server configuration
LANGFLOW_HOST=0.0.0.0
LANGFLOW_PORT=7860

# Database connection (auto-constructed from POSTGRES_USER and POSTGRES_PASSWORD)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
LANGFLOW_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/langflow

# Security (REQUIRED for production)
# IMPORTANT: Must be a valid Fernet key (44 characters, base64-encoded)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LANGFLOW_SECRET_KEY=CHANGE_ME_TO_VALID_FERNET_KEY

# Auto login (set to False for production)
LANGFLOW_AUTO_LOGIN=False

# Logging level
LANGFLOW_LOG_LEVEL=info

# ============================================================================
# Superuser Configuration
# ============================================================================

LANGFLOW_SUPERUSER=alex
LANGFLOW_SUPERUSER_PASSWORD=CHANGE_ME_SUPERUSER_PASSWORD

# ============================================================================
# Ollama Configuration
# ============================================================================

# LangFlow connects to Ollama via host.docker.internal
# The extra_hosts in docker-compose maps host.docker.internal to host-gateway

# ============================================================================
# FastAPI Configuration (PEl06)
# ============================================================================

# Backend type: langflow or langchain
BACKEND_TYPE=langflow

# LangFlow configuration (if BACKEND_TYPE=langflow)
LANGFLOW_URL=https://langflow.alex-n8n.site
LANGFLOW_FLOW_ID=eaa36f47-604c-4c62-902b-d4c84ffde61a
LANGFLOW_API_KEY=your_langflow_api_key

# LangChain configuration (if BACKEND_TYPE=langchain)
# OPENAI_API_KEY=your_openai_api_key
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma2:9b

# API configuration
API_KEY=your_api_key_optional
# CORS: Only trusted origins for production
# Web UI: https://prompt-review-demo.alex-n8n.site
# API docs: https://prompt-review-api.alex-n8n.site
# Development: http://localhost:3000
# Telegram bot: server-to-server, no CORS needed
CORS_ORIGINS=http://localhost:3000,https://prompt-review-demo.alex-n8n.site,https://prompt-review-api.alex-n8n.site

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Limits
REQUEST_TIMEOUT_SECONDS=30
MAX_PROMPT_LENGTH=10000

# ============================================================================
# Telegram Bot Configuration (PEl06 - Telegram UI)
# ============================================================================

# Telegram Bot Token (REQUIRED for Telegram UI)
# Get from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Prompt Review API URL
# URL of the FastAPI service for the Telegram bot to connect to
PROMPT_REVIEW_API_URL=http://localhost:8000

# API Timeout (seconds)
# Timeout for API requests from Telegram bot
API_TIMEOUT=60

# ============================================================================
# Notes
# ============================================================================
#
# Required variables (must be set before starting):
#   - POSTGRES_PASSWORD
#   - LANGFLOW_SECRET_KEY
#   - LANGFLOW_SUPERUSER_PASSWORD
#   - LANGFLOW_API_KEY (for LangFlow backend)
#   - OPENAI_API_KEY (for LangChain backend)
#   - TELEGRAM_BOT_TOKEN (for Telegram UI)
#
# Security recommendations:
#   - Use strong, unique passwords
#   - Never commit .env file to version control
#   - Use different credentials for production and development